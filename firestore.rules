rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /attendance_records/{recordId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.lastUpdatedBy == request.auth.uid;
      allow update: if request.auth != null && resource.data.lastUpdatedBy == request.auth.uid && request.resource.data.lastUpdatedBy == request.auth.uid;
      allow delete: if request.auth != null && resource.data.lastUpdatedBy == request.auth.uid;
    }
  }
}
